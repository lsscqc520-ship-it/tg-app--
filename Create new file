<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>系统安全登录入口</title>
    <!-- 接入电报官方环境脚本 -->
    <script src="https://telegram.org"></script>
    <style>
        body { margin: 0; padding: 0; background: #0b0e14; color: #fff; font-family: sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; }
        .login-card { background: #141923; width: 85%; max-width: 360px; border-radius: 12px; padding: 25px; border: 1px solid #25314a; box-shadow: 0 8px 16px rgba(0,0,0,0.3); text-align: center; }
        .logo { font-size: 40px; margin-bottom: 10px; color: #ffaa00; }
        .title { font-size: 20px; font-weight: bold; margin-bottom: 20px; }
        .input-box { width: 100%; padding: 12px; background: #07090d; border: 1px solid #2c3852; border-radius: 6px; color: #fff; font-size: 14px; margin-bottom: 15px; box-sizing: border-box; }
        .btn-login { width: 100%; padding: 12px; background: linear-gradient(135deg, #ffaa00 0%, #d48800 100%); border: none; border-radius: 6px; color: #000; font-size: 16px; font-weight: bold; cursor: pointer; }
        .tg-tip { font-size: 11px; color: #8a96a3; margin-top: 15px; }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="logo">🔐</div>
        <div class="title">全球娱乐综合大厅</div>
        
        <input type="text" class="input-box" placeholder="请输入账号 / 电报用户" id="username">
        <input type="password" class="input-box" placeholder="请输入安全密码" id="password">
        
        <button class="btn-login" onclick="handleLogin()">安全登录 / 快速开户</button>
        
        <div class="tg-tip" id="tg-info">正在安全校验电报会话生态...</div>
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        tg.expand();

        // 自动识别电报用户并填入
        if (tg.initDataUnsafe && tg.initDataUnsafe.user) {
            document.getElementById('username').value = tg.initDataUnsafe.user.first_name;
            document.getElementById('tg-info').innerText = `已无感关联您的电报账号 ID: ${tg.initDataUnsafe.user.id}`;
        }

        function handleLogin() {
            const user = document.getElementById('username').value;
            if(!user) { alert('请输入账号！'); return; }
            
            // 登录成功后，底层逻辑自动切到大厅主页
            window.location.href = "lobby.html"; 
        }
    </script>
</body>
</html>
